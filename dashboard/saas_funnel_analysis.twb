      <aliases enabled='yes' />
      <column caption='Paid Customers' datatype='integer' name='[Calculation_0392265450065920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [converted_to_paid]==&quot;Yes&quot; then 1 ELSE 0 END' />
      </column>
      <column caption='Conversion Rate' datatype='real' name='[Calculation_0392265450758145]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [converted_to_paid] = &quot;Yes&quot;&#13;&#10;    THEN 1&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([user_id])' />
      </column>
      <column caption='30-Day Retention Rate' datatype='real' name='[Calculation_0392265452183554]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [active_after_30_days] = &quot;Yes&quot;&#13;&#10;    THEN 1&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;    IF [active_after_30_days] = &quot;Yes&quot;&#13;&#10;    OR [active_after_30_days] = &quot;No&quot;&#13;&#10;    THEN 1&#13;&#10;    ELSE 0&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Channel conversion rate' datatype='real' name='[Calculation_1049498684993536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [converted_to_paid] == &quot;Yes&quot; THEN 1 ELSE 0 END)/COUNT([user_id])' />
      </column>
